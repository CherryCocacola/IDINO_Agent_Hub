<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <config>
    <!-- NuGet 소스 접속 시 프록시 우회: 127.0.0.1 프록시 403 방지 -->
    <add key="no_proxy" value="api.nuget.org,nuget.org" />
    <add key="signatureValidationMode" value="accept" />
  </config>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
</configuration>
