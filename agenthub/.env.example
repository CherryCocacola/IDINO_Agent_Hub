# =============================================================================
# AgentHub - Docker Compose 환경변수 템플릿
# ---------------------------------------------------------------------------
# 사용:
#   1) 본 파일을 `.env` 로 복사: cp .env.example .env
#   2) 각 시크릿 값 입력 (앞뒤 따옴표 X, 공백 X)
#   3) `docker compose up -d`
#
# 보안:
#   - `.env` 는 `.gitignore` 대상 (커밋 금지)
#   - JWT 키 / AES 키 / API 키 누출 시 즉시 회전
#   - POSTGRES_PASSWORD 는 docutil 스택의 docutil-postgres 컨테이너 시크릿과
#     동일해야 함 (`/home/idino/docutil/.env` 의 POSTGRES_PASSWORD 참조)
# =============================================================================

# === DB (docutil-postgres 컨테이너 내부의 AGENT_HUB user/DB 비밀번호) ===
# docutil 컨테이너 부팅 시 init script 가 별도로 AGENT_HUB user 를 생성하며,
# 그 비밀번호는 docutil 의 POSTGRES_PASSWORD 와 다르다(통합 PG 사양 ≠ docutil 슈퍼유저).
AGENT_HUB_DB_PASSWORD=

# === Redis (docutil-redis 컨테이너 비밀번호) ===
# docutil/.env 의 REDIS_PASSWORD 와 동일해야 함 (인증 필수).
REDIS_PASSWORD=

# === JWT 발급 시크릿 (운영 환경 32자+ 강한 랜덤 권장) ===
JWT_SECRET_KEY=

# === ApiKey AES 암호화 키 (Base64 인코딩, 32바이트=AES-256) ===
# 미설정 시 JWT 키 SHA-256 폴백 (TECHSPEC §16 C2 — 운영 시 별도 키 필수)
ENCRYPTION_API_KEY_AES_KEY=

# === DocUtil 운영자 토큰 ===
# DocUtil 의 /api/v1/auth/login 으로 운영자 계정 로그인 후 access_token 입력 (선택).
# 만료 30분이지만 IDocUtilTokenProvider 가 만료 5분 전부터 자동 refresh / re-login.
# 비어 있어도 ServiceUsername/Password 가 있으면 자동 발급됨.
DOCUTIL_JWT_TOKEN=

# DocUtil ServiceAccount (자동 토큰 갱신용 — refresh 실패 시 재로그인)
# JwtToken 미설정 또는 만료된 경우 본 자격으로 /api/v1/auth/login 호출.
DOCUTIL_SERVICE_USERNAME=
DOCUTIL_SERVICE_PASSWORD=

# 또는 영구 ApiKey (DocUtil 운영자가 발급한 영구 키, 우선순위 최하 — refresh 무관)
DOCUTIL_API_KEY=

# === Nexus (LAN-only, ADR-11) ===
# 외부망 노출 금지. 미배포 시 빈 값으로 두면 Hybrid Agent 가 external 폴백.
NEXUS_BASE_URL=http://192.168.22.28:8001
NEXUS_SHARED_SECRET=

# === 외부 LLM 프로바이더 키 ===
OPENAI_API_KEY=
CLAUDE_API_KEY=
GEMINI_API_KEY=
PERPLEXITY_API_KEY=
TAVILY_API_KEY=
