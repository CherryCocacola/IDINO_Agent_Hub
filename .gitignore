# ─── Docker / Compose ────────────────────────────────────────────────
docker-compose.override.yml
.docker/

# ─── 데이터/모델 (대용량) ──────────────────────────────────────────────
# 주의: `data/` `models/` `checkpoints/` 디렉토리 패턴은 사용 금지
# (Windows의 case-insensitive 매칭이 .NET 표준 `Data/`/`Models/`와
#  Python ORM `models/` 모듈까지 차단함. 파일 확장자 패턴으로만 막는다)
*.bin
*.safetensors
*.pt
*.pth
*.onnx
*.gguf
# 대용량 데이터 디렉토리는 시스템별로 명시 (예: nexus/data/, nexus/checkpoints/)

# ─── Nexus 전용 ──────────────────────────────────────────────────────
.nexus/
nexus/checkpoints/
nexus/data/
# nexus 런타임 시크릿 (평문 password 포함) — *.example만 커밋
nexus/config/nexus_config.yaml
nexus/config/permission_rules.yaml
nexus/config/tenants.yaml
nexus/config/ssl/
nexus/config/secrets.yaml

# ─── 운영 설정 (시크릿 포함 가능) ─────────────────────────────────────
# 각 서브프로젝트의 실제 운영 설정은 env/vault로 관리
**/secrets.yaml
**/secrets.json
**/secret.json

# ─── 데이터베이스 백업 ────────────────────────────────────────────────
*.bak
*.backup
*.dump
*.sql.gz

# ─── 테스트 산출물 ────────────────────────────────────────────────────
test-results/
playwright-report/
.playwright-mcp/
coverage/

# ─── 로컬 작업물 ─────────────────────────────────────────────────────
nul
nu_
*.lock-info
.scheduled_tasks.lock

# ─── e2e Playwright storage state (JWT/refreshToken 포함 — 절대 커밋 금지) ───
# 트랙 #83 (2026-05-12) — admin_state.json 에 JWT token + refreshToken 평문 포함 확인됨.
# 모든 *_state.json 패턴을 차단하여 향후 자동화 토큰 누설 방지.
tools/ui_e2e/full/_admin_state.json
tools/ui_e2e/full/*_state.json
tools/ui_e2e/full/_state_*.json
tools/ui_e2e/**/storage_state*.json
