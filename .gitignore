.vscode/
.idea/
*.swp
*.swo
*~
*.user
*.suo
*.userosscache
*.sln.docstates

# 환경 변수 / 시크릿 (절대 커밋 금지)
.env
.env.local
.env.development.local
.env.test.local

# Phase 7.2 시연용 ApiKey 평문 출력 (절대 커밋 금지)
user_mig/tools/.phase72_keys.json
.env.production.local
.env.*.local
*.env
appsettings.Development.json
appsettings.Production.json
secrets.json
*.pem
*.key
*.pfx
*.crt

# 로그
logs/
*.log
log/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# 임시
tmp/
temp/
*.tmp
*.bak
*.orig

