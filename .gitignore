# ─── Python (docutil/backend, career, nexus) ─────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
*.egg
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
