# Database Common
DB_HOST=localhost
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=2012

# Service-specific schemas
AUTH_DB_SCHEMA=idino_career_auth
STUDENT_DB_SCHEMA=idino_career_student
COMPETENCY_DB_SCHEMA=idino_career_competency
ROADMAP_DB_SCHEMA=idino_career_roadmap
ALUMNI_DB_SCHEMA=idino_career_alumni
AI_DB_SCHEMA=idino_career_ai
INTEGRATION_DB_SCHEMA=idino_career_integration

# Redis (for auth sessions & cache)
REDIS_URL=redis://localhost:6379/0

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# JWT Configuration
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# AI Service
OPENAI_API_KEY=sk-...

# ============================================
# AgentHub — Phase 7.2 단일 진입점 (R2)
# --------------------------------------------
# career 18 MS 의 모든 LLM 호출을 AgentHub 의 OpenAI 호환 엔드포인트로 위임한다.
# Phase 7.4 에서 shared.common.agenthub_client.get_agenthub_client() 가 본 값을 로드하여 사용.
# 운영 환경에서는 AgentHub UI 에서 정식 발급 절차로 키를 회전한다.
# ============================================
AGENTHUB_URL=http://localhost:5000
AGENTHUB_API_KEY=CHANGE_ME_agenthub_api_key
AGENTHUB_CONSUMER=career

# Service Ports
AUTH_SERVICE_PORT=8001
STUDENT_SERVICE_PORT=8002
COMPETENCY_SERVICE_PORT=8003
ROADMAP_SERVICE_PORT=8004
ALUMNI_SERVICE_PORT=8005
AI_SERVICE_PORT=8006
INTEGRATION_SERVICE_PORT=8007
