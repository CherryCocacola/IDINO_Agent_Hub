# Database Common
DB_HOST=localhost
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=2012

# Service-specific schemas
AUTH_DB_SCHEMA=idino_career_auth
STUDENT_DB_SCHEMA=idino_career_student
COMPETENCY_DB_SCHEMA=idino_career_competency
ROADMAP_DB_SCHEMA=idino_career_roadmap
ALUMNI_DB_SCHEMA=idino_career_alumni
AI_DB_SCHEMA=idino_career_ai
INTEGRATION_DB_SCHEMA=idino_career_integration

# Redis (for auth sessions & cache)
