    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dompurify": "^3.2.0",
    "lucide-react": "^0.460.0",
    "motion": "^12.0.0",
    "next": "^16.0.0",
    "next-themes": "^0.4.4",
    "nuqs": "^2.3.0",
    "react": "^19.1.0",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.1.0",
    "react-dropzone": "^14.3.5",
    "react-markdown": "^9.0.0",
    "recharts": "^2.14.1",
