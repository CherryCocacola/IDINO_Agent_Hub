###############################################################################
# Document Utilization System - Environment Variables
# ---------------------------------------------------------------------------
# Copy this file to .env and fill in the values before running docker compose.
#
#   cp .env.example .env
#
# SECURITY: Never commit .env to version control.
###############################################################################

# ==========================================================================
# General / Application
# ==========================================================================
APP_NAME=document-utilization
APP_ENV=production                   # development | staging | production
DEBUG=false
LOG_LEVEL=info                       # debug | info | warning | error | critical
TIMEZONE=UTC
ALLOWED_HOSTS=localhost,127.0.0.1

# ==========================================================================
# PostgreSQL
# ==========================================================================
POSTGRES_USER=docutil
POSTGRES_PASSWORD=CHANGE_ME_postgres_password
POSTGRES_DB=docutil
POSTGRES_PORT=5432
# Constructed automatically in docker-compose.yml:
#   DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}
#   DATABASE_URL_SYNC=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}

# ==========================================================================
# Redis
# ==========================================================================
REDIS_PASSWORD=CHANGE_ME_redis_password
REDIS_PORT=6379
REDIS_DB=0
REDIS_CELERY_DB=1
REDIS_MAXMEMORY=512mb
# Constructed automatically in docker-compose.yml:
#   REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/${REDIS_DB}

# ==========================================================================
# RabbitMQ
# ==========================================================================
RABBITMQ_USER=docutil
RABBITMQ_PASSWORD=CHANGE_ME_rabbitmq_password
RABBITMQ_VHOST=/
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672
# Constructed automatically in docker-compose.yml:
#   RABBITMQ_URL=amqp://${RABBITMQ_USER}:${RABBITMQ_PASSWORD}@rabbitmq:5672/${RABBITMQ_VHOST}

# ==========================================================================
# MinIO (Object Storage)
# ==========================================================================
MINIO_ROOT_USER=docutil
MINIO_ROOT_PASSWORD=CHANGE_ME_minio_password
MINIO_USE_SSL=false
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BROWSER_REDIRECT_URL=http://localhost:9001
MINIO_DEFAULT_BUCKET=documents

# ==========================================================================
# Qdrant (Vector Database)
# ==========================================================================
QDRANT_API_KEY=
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_COLLECTION_NAME=doc_embeddings
# Constructed automatically in docker-compose.yml:
#   QDRANT_URL=http://qdrant:6333

# ==========================================================================
# Authentication / JWT
# ==========================================================================
# Generate with:  openssl rand -hex 32
JWT_SECRET_KEY=CHANGE_ME_jwt_secret_at_least_32_chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ==========================================================================
# Encryption
# ==========================================================================
# Generate with:  python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=CHANGE_ME_fernet_encryption_key
# Generate with:  openssl rand -hex 32
FIELD_ENCRYPTION_KEY=CHANGE_ME_field_encryption_key

# ==========================================================================
# LLM / AI Services
# ==========================================================================
# -- OpenAI-compatible API (used when external LLM provider is selected) ---
OPENAI_API_KEY=
OPENAI_ORG_ID=
OPENAI_MODEL=gpt-4o

# -- Anthropic ---------------------------------------------------------------
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# -- Azure OpenAI ------------------------------------------------------------
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=2024-06-01
AZURE_OPENAI_DEPLOYMENT=

# -- Google Gemini -----------------------------------------------------------
GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-2.0-flash

# -- Default LLM provider (openai | azure_openai | anthropic | gemini | vllm)
LLM_PROVIDER=openai

# ==========================================================================
# AgentHub — Phase 7.2 단일 진입점 (R2)
# --------------------------------------------------------------------------
# DocUtil 의 모든 LLM 호출을 AgentHub 의 OpenAI 호환 엔드포인트로 위임한다.
# Phase 7.3 에서 app/integrations/agenthub_client.py 가 본 값을 로드하여 사용.
# 운영 환경에서는 AgentHub UI 에서 정식 발급 절차로 키를 회전한다.
# ==========================================================================
AGENTHUB_URL=http://localhost:5000
AGENTHUB_API_KEY=CHANGE_ME_agenthub_api_key

# -- Per-feature provider overrides (optional, defaults to LLM_PROVIDER) ----
# CHAT_LLM_PROVIDER=
# REPORT_LLM_PROVIDER=
# TEMPLATE_LLM_PROVIDER=

# ==========================================================================
# vLLM (Self-hosted LLM - requires GPU)
# ==========================================================================
VLLM_BASE_URL=http://vllm:8001/v1
VLLM_MODEL=Qwen/Qwen3-32B-AWQ
VLLM_MAX_MODEL_LEN=32768
VLLM_GPU_MEMORY_UTIL=0.90
VLLM_PORT=8001

# ==========================================================================
# Embedding Service (requires GPU)
# ==========================================================================
EMBEDDING_SERVICE_URL=http://embedding:8002
EMBEDDING_MODEL=Qwen/Qwen3-Embedding-8B
EMBEDDING_DIMENSION=2048
EMBEDDING_PORT=8002

# ==========================================================================
# Reranker Service (requires GPU)
# ==========================================================================
RERANKER_SERVICE_URL=http://reranker:8003
RERANKER_MODEL=Qwen/Qwen3-Reranker-8B
RERANKER_PORT=8003

# ==========================================================================
# Docling Service (requires GPU)
# ==========================================================================
DOCLING_SERVICE_URL=http://granite-docling:5000
DOCLING_PORT=8005

# ==========================================================================
# SGLang (alternative LLM serving)
# ==========================================================================
SGLANG_BASE_URL=http://sglang:30000

# ==========================================================================
# HuggingFace (model downloads for GPU services)
# ==========================================================================
HF_TOKEN=

# ==========================================================================
# Celery
# ==========================================================================
CELERY_WORKER_CONCURRENCY=4
CELERY_MAX_TASKS_PER_CHILD=100
CELERY_WORKER_REPLICAS=2
CELERY_WORKER_MEMORY_LIMIT=2G

# ==========================================================================
# Flower (Celery Monitoring)
# ==========================================================================
FLOWER_USER=admin
FLOWER_PASSWORD=CHANGE_ME_flower_password
FLOWER_PORT=5555

# ==========================================================================
# Frontend (Next.js)
# ==========================================================================
NODE_ENV=production
FRONTEND_PORT=3002
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
NEXT_PUBLIC_MINIO_URL=http://localhost:9000

# ==========================================================================
# Nginx
# ==========================================================================
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# ==========================================================================
# Prometheus
# ==========================================================================
PROMETHEUS_PORT=9090
PROMETHEUS_RETENTION=15d

# ==========================================================================
# Grafana
# ==========================================================================
GRAFANA_PORT=3001
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_grafana_password
GRAFANA_ROOT_URL=http://localhost:3001

# ==========================================================================
# Loki
# ==========================================================================
LOKI_PORT=3100

# ==========================================================================
# API Service
# ==========================================================================
API_PORT=8000
API_WORKERS=4
API_CORS_ORIGINS=http://localhost:3002,http://localhost:80
API_RATE_LIMIT=100/minute

# ==========================================================================
# OCR
# ==========================================================================
OCR_ENGINE=tesseract                 # tesseract | azure | google
AZURE_DOCUMENT_INTELLIGENCE_KEY=
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=
GOOGLE_VISION_CREDENTIALS_PATH=

# ==========================================================================
# Email (optional, for notifications)
# ==========================================================================
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com
SMTP_USE_TLS=true

# ==========================================================================
# Sentry (optional, error tracking)
# ==========================================================================
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1

# ==========================================================================
# OpenTelemetry
# ==========================================================================
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=document-utilization
OTEL_TRACES_SAMPLER=parentbased_traceidratio
OTEL_TRACES_SAMPLER_ARG=0.1
