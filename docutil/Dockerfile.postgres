# 트랙 #144 (2026-06-01) — pgvector/pg17 베이스 이미지에 ko_KR.UTF-8 locale 영구 적용.
#
# 운영 결함 (2026-06-01): docutil-postgres 컨테이너 재시작 후
#   FATAL: database locale is incompatible with operating system
#   DETAIL: The database was initialized with LC_COLLATE "ko_KR.UTF-8",
#           which is not recognized by setlocale().
#
# Root cause: pgvector/pgvector:pg17 (Debian bookworm) 이미지가 minimal 빌드라
#   locales-all 패키지 미포함 → ko_KR.UTF-8 locale 인식 실패 → DB cluster 가
#   자기 자신을 열지 못함.
#
# Fix: locales-all 패키지를 빌드 단계에서 영구 설치. 본 Dockerfile 을 통해
#   image 가 한 번 빌드되면 컨테이너 재생성/재배포 시에도 결함 재발 없음.

FROM pgvector/pgvector:pg17

RUN apt-get update \
    && apt-get install -y --no-install-recommends locales-all \
    && rm -rf /var/lib/apt/lists/*

# 컨테이너 environment 에 한국어 기본 locale 명시 (선택 — 기존 PGDATA 의 locale 과 일치).
ENV LANG=ko_KR.UTF-8 \
    LC_COLLATE=ko_KR.UTF-8 \
    LC_CTYPE=ko_KR.UTF-8
